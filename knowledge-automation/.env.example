# LLM Provider Configuration
# ========================
# Copy this file to .env and fill in your API keys.

# Default provider: deepseek | qwen | openai
LLM_PROVIDER=deepseek

# ------------------------------------------------------------------
# DeepSeek
# ------------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_DEFAULT_MODEL=deepseek-chat
DEEPSEEK_PRICING_INPUT=0.27
DEEPSEEK_PRICING_OUTPUT=1.10

# ------------------------------------------------------------------
# Qwen (DashScope / 通义千问)
# ------------------------------------------------------------------
DASHSCOPE_API_KEY=sk-your-qwen-key-here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_DEFAULT_MODEL=qwen-max
QWEN_PRICING_INPUT=0.40
QWEN_PRICING_OUTPUT=1.60

# ------------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_PRICING_INPUT=2.50
OPENAI_PRICING_OUTPUT=10.00
